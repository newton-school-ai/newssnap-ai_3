# NewsSnap AI - Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://newssnap:newssnap@localhost:5432/newssnap
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=newssnap_master_key

# LLM - Groq (recommended, free tier)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# LLM - OpenAI (optional, paid)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# LLM - Anthropic (optional, paid)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# JWT
JWT_SECRET_KEY=generate_with_python_secrets_token_hex_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Scraper
SCRAPE_INTERVAL_MINUTES=10
SCRAPE_RATE_LIMIT_SECONDS=2
SCRAPE_MAX_RETRIES=3
SCRAPE_UNHEALTHY_THRESHOLD=5
PLAYWRIGHT_HEADLESS=true

# Content Pipeline
DEDUP_SIMILARITY_THRESHOLD=0.85
DEDUP_WINDOW_HOURS=48
SUMMARY_MIN_WORDS=40
SUMMARY_MAX_WORDS=100
SUMMARY_TARGET_WORDS=70
QUALITY_THRESHOLD=0.4

# Translation
SUPPORTED_LANGUAGES=en,hi,ta,te,kn
DEFAULT_LANGUAGE=en

# Recommendation
CONTENT_BASED_WEIGHT=0.4
COLLABORATIVE_WEIGHT=0.35
TRENDING_WEIGHT=0.25
DIVERSITY_RATIO=0.2
RECOMMENDATION_REFRESH_MINUTES=30
COLLABORATIVE_RETRAIN_HOURS=6

# Snap Generation
SNAP_WIDTH=1080
SNAP_HEIGHT=1920
SNAP_IMAGE_MAX_KB=500
SNAP_OUTPUT_DIR=data/snaps

# Cleanup
CLEANUP_ARCHIVE_DAYS=14
CLEANUP_DELETE_DAYS=21
CLEANUP_CRON_HOUR=3
CLEANUP_CRON_MINUTE=0

# Push Notifications (Firebase Cloud Messaging)
# FCM_CREDENTIALS_PATH=path/to/firebase-credentials.json
# FCM_PROJECT_ID=your_firebase_project_id

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT_PER_MINUTE=100
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
